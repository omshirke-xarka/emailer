{
  "name": "emailer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n redis,server,client \"npm run dev:redis\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:redis": "docker compose -f backend/docker-compose.yml up -d redis",
    "dev:server": "node scripts/dev-backend.mjs",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
