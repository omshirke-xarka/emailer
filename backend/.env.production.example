# Production environment for EC2 deployment.
# Copy to .env on the server: cp .env.production.example .env

# Server Configuration
PORT=3001
NODE_ENV=production

# Domain the API is served from (Caddy obtains the HTTPS certificate for it).
# Create a DNS A record for this name pointing to the EC2 public IP first.
API_DOMAIN=api.yourdomain.com

# Public base URL for tracking pixels/links — https:// + API_DOMAIN
APP_URL=https://api.yourdomain.com

# Browser origins allowed to call this API (your Vercel URLs, comma-separated)
CORS_ORIGINS=https://your-app.vercel.app

# Email provider: aws | resend
EMAIL_PROVIDER=aws
SENDER_EMAIL=LawgicHub <noreply@lawgichub.com>

# Email Rate Limiting
EMAIL_RATE_LIMIT_INTERVAL_MS=1000
EMAIL_RATE_LIMIT_MAX_PER_MINUTE=60
EMAIL_RATE_LIMIT_MAX_PER_HOUR=3600

# Tracking: ignore opens/clicks within this many seconds of the send
# (mail-provider scanners fetch the pixel right after delivery)
OPEN_TRACKING_GRACE_SECONDS=10
# Rewrite links through /api/track/click for click tracking
ENABLE_CLICK_TRACKING=false

# AWS SES Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@lawgichub.com
SES_SENDER_NAME=

# Resend Configuration (only if EMAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=LawgicHub <noreply@lawgichub.com>

# Redis — leave as-is, docker-compose overrides it to the redis container
REDIS_URL=redis://redis:6379
